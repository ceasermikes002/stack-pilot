# ------------------------------------------------------------------------------
# {{projectName}} Environment Variables
# ------------------------------------------------------------------------------

# Database (PostgreSQL)
# Get a free postgres URL from Supabase, Neon, or run docker-compose up
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/{{projectName}}?schema=public"

# Authentication (Clerk)
# Get these keys from https://dashboard.clerk.dev
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk Redirects
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Payments (Stripe) - if enabled
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
