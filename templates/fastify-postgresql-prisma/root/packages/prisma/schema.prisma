datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User Model tailored for Clerk Syncing
model User {
  id        String   @id @default(cuid()) // Your internal ID
  clerkId   String   @unique             // ID from Clerk Auth
  email     String   @unique
  firstName String?
  lastName  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
