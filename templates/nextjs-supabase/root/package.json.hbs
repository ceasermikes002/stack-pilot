{
"name": "{{projectName}}",
"private": true,
"scripts": {
"build": "turbo build",
"dev": "turbo dev",
"lint": "turbo lint",
"format": "prettier --write \"**/*.{ts,tsx,md}\"",
"db:push": "supabase db push",
"db:generate": "supabase gen types typescript --local > types/supabase.ts"
},
"devDependencies": {
"prettier": "^3.2.5",
"turbo": "^2.0.4",
"typescript": "^5.4.5"
},
"engines": {
"node": ">=22"
},
"packageManager": "npm@10.2.4",
"workspaces": [
"apps/*",
"packages/*"
]
}